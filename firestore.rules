rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar sadece kendi profillerini okuyup yazabilir
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        resource.data.companyId == getUserCompanyId()
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Şirket bilgileri: sadece admin okuyup yazabilir
    match /companies/{companyId} {
      allow read: if request.auth != null && getUserCompanyId() == companyId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && isAdmin(companyId);

      // Alt koleksiyonlar için
      match /vehicles/{vehicleId} {
        allow read: if request.auth != null && getUserCompanyId() == companyId;
        allow write: if request.auth != null && getUserCompanyId() == companyId && isAdmin(companyId);
        // Araç KM güncellemesi için sürücülere de izin ver
        allow update: if request.auth != null && getUserCompanyId() == companyId;
      }

      match /trips/{tripId} {
        allow read: if request.auth != null && getUserCompanyId() == companyId;
        allow create: if request.auth != null && getUserCompanyId() == companyId;
        allow update, delete: if request.auth != null && getUserCompanyId() == companyId && (
          isAdmin(companyId) || resource.data.driverUid == request.auth.uid
        );
      }

      match /fuel/{fuelId} {
        allow read: if request.auth != null && getUserCompanyId() == companyId;
        allow create: if request.auth != null && getUserCompanyId() == companyId;
        allow update, delete: if request.auth != null && getUserCompanyId() == companyId && (
          isAdmin(companyId) || resource.data.driverUid == request.auth.uid
        );
      }
    }

    // Yardımcı fonksiyonlar
    function getUserCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function isAdmin(companyId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
